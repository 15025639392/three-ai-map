{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/datasets/oblique-3dtiles-manifest.schema.json",
  "title": "Oblique3DTilesManifest",
  "type": "object",
  "required": ["schemaVersion", "datasetFamily", "updatedAt", "datasets"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "datasetFamily": {
      "const": "oblique-3dtiles"
    },
    "updatedAt": {
      "type": "string"
    },
    "datasets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "scope", "description", "format", "sizeBytes", "sha256"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "scope": {
            "type": "string",
            "enum": ["deterministic-fixture", "remote-reference"]
          },
          "description": { "type": "string", "minLength": 1 },
          "format": { "type": "string", "minLength": 1 },
          "entryFile": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "format": "uri" },
          "downloadFile": { "type": "string", "minLength": 1 },
          "sizeBytes": { "type": "integer", "minimum": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "scope": { "const": "deterministic-fixture" }
              }
            },
            "then": {
              "required": ["entryFile"]
            }
          },
          {
            "if": {
              "properties": {
                "scope": { "const": "remote-reference" }
              }
            },
            "then": {
              "required": ["url", "downloadFile"]
            }
          }
        ]
      }
    }
  }
}
